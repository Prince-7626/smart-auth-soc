# SMART AUTH SOC Configuration
# Copy this file to .env and update values for your environment

# Flask Configuration
FLASK_ENV=development
FLASK_DEBUG=True
SECRET_KEY=your-secret-key-here

# Database Configuration
# Development (SQLite)
DATABASE_URL=sqlite:///smartauth_soc.db

# Production (PostgreSQL) - Uncomment and configure for production
# DATABASE_URL=postgresql://user:password@localhost:5432/smartauth_soc

# Database Credentials (for production)
DB_USER=postgres
DB_PASSWORD=
DB_HOST=localhost
DB_PORT=5432
DB_NAME=smartauth_soc

# Environment
ENVIRONMENT=development

# API Configuration
GEOIP_API_KEY=
THREAT_INTEL_API_KEY=

# Security
SESSION_TIMEOUT=30
LOGIN_ATTEMPTS_THRESHOLD=6
LOGIN_BLOCK_DURATION=10

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/application.log

# Features
ENABLE_2FA=False
ENABLE_LDAP=False
ENABLE_SINGLE_SIGN_ON=False
